OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small

# Vector DB. Local: a Docker container (no API key). Cloud (Qdrant Cloud): an https URL
# plus an API key.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis. Local: a Docker container. Cloud (Upstash): a rediss:// URL with credentials.
REDIS_URL=redis://localhost:6379/0

COST_DB_PATH=data/costs.db

# Observability — optional; tracing turns on only when both keys are set.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
